@page "/admin-dashboard"
@layout AdminLayout
@inherits BaseComponent
@using EPPSchedulerFrontend.DataClasses

<PageTitle>EPP Scheduler | Admin Dashboard</PageTitle>
@if (!displayInProgress)
{
    <MudSelect @bind-Value="_selectedScheduleProfile" @bind-Value:after="@displayScheduleProfile">
        @foreach (string name in scheduleProfileNames)
        {
            <MudSelectItem Value="@name">@name</MudSelectItem>
        }
    </MudSelect>
}
<MudContainer>
    <MudDataGrid Items="@Elements" Filterable="false">
        <Columns>
            <PropertyColumn Property="x => x.timeSlot.ToString()" Title="Time">
            </PropertyColumn>
            <PropertyColumn Property="x => x.sunday.ToString()" Title="Sunday">
            </PropertyColumn>
            <PropertyColumn Property="x => x.monday.ToString()" Title="Monday">
            </PropertyColumn>
            <PropertyColumn Property="x => x.tuesday.ToString()" Title="Tuesday">
            </PropertyColumn>
            <PropertyColumn Property="x => x.wednesday.ToString()" Title="Wednesday">
            </PropertyColumn>
            <PropertyColumn Property="x => x.thursday.ToString()" Title="Thursday">
            </PropertyColumn>
            <PropertyColumn Property="x => x.friday.ToString()" Title="Friday">
            </PropertyColumn>
            <PropertyColumn Property="x => x.saturday.ToString()" Title="Saturday">
            </PropertyColumn>
        </Columns>
    </MudDataGrid>
</MudContainer>

@code {

    private bool displaySchedule = false;

    private IEnumerable<TimeSlot> Elements = new List<TimeSlot>();

    private string _selectedScheduleProfile;

    List<ScheduleProfile> scheduleProfiles = new List<ScheduleProfile>();

    List<string> scheduleProfileNames = new List<string>();
    
    private bool displayInProgress = false;
    
    protected override async Task OnInitializedAsync()
    {
        HttpClient client = clientFactory.CreateClient("EPPSchedulerBackend");

        HttpResponseMessage resp = await client.GetAsync("api/ScheduleProfile");
        try
        {
            resp.EnsureSuccessStatusCode();
        }
        catch (HttpRequestException)
        {
            snackbar.Add("Failed to get list of schedule profiles", Severity.Error);
            return;
        }

        scheduleProfiles = await resp.Content.ReadFromJsonAsync<List<ScheduleProfile>>();

        foreach (ScheduleProfile scheduleProfile in scheduleProfiles)
        {
            scheduleProfileNames.Add(scheduleProfile.name);
        }
    }

    private async void displayScheduleProfile()
    {
        displayInProgress = true;

        ScheduleProfile currentProfile = scheduleProfiles.First(x => x.name == _selectedScheduleProfile);

        HttpClient client = clientFactory.CreateClient("EPPSchedulerBackend");

        FullSchedule resp = await client.GetFromJsonAsync<FullSchedule>($"api/FullSchedule/{currentProfile.name}");

        snackbar.Add("Got the things", Severity.Success);
    }
}