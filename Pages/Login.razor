@page "/"

@inherits BaseComponent
@using EPPSchedulerFrontend.DataClasses
@using System.ComponentModel.DataAnnotations
@using System.Net

<PageTitle>EPP Scheduler | Login</PageTitle>

<EditForm Model="@model" OnValidSubmit="OnValidLogin">
    <DataAnnotationsValidator />
    <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center mud-width-full"
                  style="height:50vh; min-height: 300px;">
        <MudGrid Spacing="2" Justify="Justify.Center" Class="align-items-center">
            <MudPaper Class="pa-4 mud-theme-primary">
                <MudItem xs="12">
                    <MudText Typo="Typo.h2" Style="font-weight:bold" Align="Align.Center">Login or Register</MudText>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="model.email" For="@(() => model.email)" Label="Username"
                                  Variant="Variant.Outlined"></MudTextField>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="model.password" For="@(() => model.password)" Label="Password"
                                  Variant="Variant.Outlined" InputType="@PasswordInput" Adornment="Adornment.End"
                                  AdornmentIcon="@PasswordInputIcon" OnAdornmentClick="OnShowClick"
                                  AdornmentAriaLabel="Show Password" AdornmentColor="@Color.Inherit" />
                </MudItem>
                <MudItem xs="12">
                    <MudGrid Justify="Justify.Center" Spacing="3">
                        <MudItem xs="6">
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" FullWidth=true
                                       StartIcon="@Icons.Material.TwoTone.Login" Color="Color.Secondary">Sign In</MudButton>
                        </MudItem>
                        <MudItem xs="6">
                            <MudButton Variant="Variant.Filled" Href="/create-account" FullWidth=true
                                       StartIcon="@Icons.Material.TwoTone.Create" Color="Color.Secondary">Create Account
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudItem>
            </MudPaper>
        </MudGrid>
    </MudContainer>
</EditForm>
@code {

    private bool showPassword = false;

    private InputType PasswordInput => showPassword ? InputType.Text : MudBlazor.InputType.Password;
    private string PasswordInputIcon => showPassword ? Icons.Material.Filled.Visibility :
Icons.Material.Filled.VisibilityOff;

    LoginForm model = new LoginForm();

    private void OnShowClick()
    {
        showPassword = !showPassword;
    }

    private async void OnValidLogin(EditContext context)
    {
        if (clientFactory is null || snackbar is null || navigationManager is null)
        {
            return;
        }
        HttpClient client = clientFactory.CreateClient("EPPSchedulerBackend");

        if (model.email is null || model.password is null)
        {
            snackbar.Add("There was an error while attempting to get your username and password, please refresh and try again",
Severity.Error);
            return;
        }

        Credentials credentials = new Credentials(model.email, model.password, null);

        HttpResponseMessage resp = await client.PostAsJsonAsync(requestUri: "api/Credentials/login", credentials);

        try
        {
            resp.EnsureSuccessStatusCode();
        }
        catch (HttpRequestException e)
        {
            if (resp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                snackbar.Add("The email is either incorrect or this account doesn't exit", Severity.Error);
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                snackbar.Add("The password is incorrect please try again", Severity.Error);
            }
            else
            {
                throw e;
            }
        }

        if (resp.StatusCode == System.Net.HttpStatusCode.OK)
        {
            navigationManager.NavigateTo("dashboard", replace: true);
        }
    }

    public class LoginForm
    {
        [Required]
        [EmailAddress]
        public string? email { get; set; }
        [Required]
        [StringLength(30, ErrorMessage = "Password Must be at least 12 characters long", MinimumLength = 12)]
        public string? password { get; set; }
    }
}