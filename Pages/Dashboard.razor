@page "/dashboard"
@using EPPSchedulerFrontend.DataClasses
@using MudBlazor.Interop
@using System.Runtime.CompilerServices
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

@inherits BaseComponent

@layout UserLayout

<PageTitle>EPP Scheduler | Dashboard</PageTitle>

<MudContainer>
    <MudDataGrid Items="@Elements">
        <Columns>
            <PropertyColumn Property="x => x.timeSlot.ToString()" Title="Time">
            </PropertyColumn>
            <PropertyColumn Property="x => x.sunday.ToString()" Title="Sunday">
            </PropertyColumn>
            <PropertyColumn Property="x => x.monday.ToString()" Title="Monday">
            </PropertyColumn>
            <PropertyColumn Property="x => x.tuesday.ToString()" Title="Tuesday">
            </PropertyColumn>
            <PropertyColumn Property="x => x.wednesday.ToString()" Title="Wednesday">
            </PropertyColumn>
            <PropertyColumn Property="x => x.thursday.ToString()" Title="Thursday">
            </PropertyColumn>
            <PropertyColumn Property="x => x.friday.ToString()" Title="Friday">
            </PropertyColumn>
            <PropertyColumn Property="x => x.saturday.ToString()" Title="Saturday">
            </PropertyColumn>
        </Columns>
    </MudDataGrid>
</MudContainer>

@code {

    private IEnumerable<TimeSlot> Elements = new List<TimeSlot>();

    private Func<ScheduleMap, string> _cellStyleFunc => x =>
    {
        string style = String.Empty;
        return style;
    };

    private async Task _updateSchedule(HttpClient client)
    {
        if (snackbar is null || navigationManager is null)
        {
            return;
        }
        try
        {

            HttpResponseMessage resp = await
                client.GetAsync("api/ScheduleProfile/GetActiveScheduleProfile");

            if (resp.StatusCode == System.Net.HttpStatusCode.NoContent)
            {
                snackbar.Add("Your schedule is not available", Severity.Info);
            }
            else
            {
                Tuple<List<TimeInterval>, List<NestedTimeInterval>>? activeProfile =
                    JsonSerializer.Deserialize<Tuple<List<TimeInterval>, List<NestedTimeInterval>>>(resp.Content.ReadAsStream());
                List<NestedTimeInterval>? scheduleResponse = await
                    client.GetFromJsonAsync<List<NestedTimeInterval>>("api/EmployeeProfile/get-schedule");
                if (scheduleResponse == null || activeProfile == null)
                {
                    snackbar.Add("No schedule data was found, please try again", Severity.Error);
                }
                else
                {
                    ScheduleMap scheduleMap = new ScheduleMap(scheduleResponse, activeProfile.Item1);
                    foreach (TimeInterval currentHours in activeProfile.Item1)
                    {
                        for (TimeOnly i = currentHours.startTime; i < currentHours.endTime; i.AddMinutes(30))
                        {
                            Elements.Append(new TimeSlot(scheduleMap, i));
                        }
                    }
                }
            }
        }
        catch (HttpRequestException)
        {
            snackbar.Add("There was an error while retrieving the schedule, please try again", Severity.Error);
        }
    }
    protected override async Task OnInitializedAsync()
    {
        if (authenticationService is null || clientFactory is null || navigationManager is null)
        {
            return;
        }
        HttpClient client = clientFactory.CreateClient("EPPSchedulerBackend");

        AuthenticationState authState = await authenticationService.GetAuthenticationStateAsync();

        if (authState.User.Claims.Any(c => c.Value == "Admin" || c.Value == "Manager"))
        {
            navigationManager.NavigateTo("admin-dashboard");
            return;
        }

        @* HttpResponseMessage resp = await client.PostAsync("api/Credentials/verify", null);
        Console.WriteLine("Verification Complete");
        try
        {
            resp.EnsureSuccessStatusCode();
        }
        catch (HttpRequestException)
        {
            if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                snackbar.Add("Session Expired");
            }
            else
            {
                snackbar.Add(message: "There was an error during authentication");
            }
            navigationManager.NavigateTo("/", replace: true);
        }

        Roles role = await resp.Content.ReadFromJsonAsync<Roles>();

        if (role == Roles.Admin || role == Roles.Manager)
        {
            navigationManager.NavigateTo("admin-dashboard");
            return;
        } *@

        await _updateSchedule(client);
    }
}