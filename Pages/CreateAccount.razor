@page "/create-account"
@inherits MainLayout
@inject HttpClient client
@inject ISnackbar snackbar
@using System.ComponentModel.DataAnnotations

<PageTitle>EPP Scheduler | Create Account</PageTitle>

<EditForm Model="@model" OnValidSubmit="CreateAccountSubmit">
<DataAnnotationsValidator/>
    <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center mud-width-full"  style="height:50vh; min-height: 300px;">
        <MudGrid Spacing="2" Justify="Justify.Center" Class="align-items-center">
            <MudPaper Class="pa-4">
                <MudItem xs="12">
                    <MudText Typo="Typo.h2" Align="Align.Center">Create Account</MudText>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="model.email" For="@(() => model.email)" Label="Username" Variant="Variant.Outlined"></MudTextField>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField
                        @bind-Value="model.password"
                        For="@(() => model.password)"
                        Label="Password"
                        Variant="Variant.Outlined"
                        InputType="@PasswordInput"
                        Adornment="Adornment.End"
                        AdornmentIcon="@PasswordInputIcon"
                        OnAdornmentClick="OnShowClick"
                        AdornmentAriaLabel="Show Password" />
                </MudItem>
                <MudItem xs="12">
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" FullWidth=true StartIcon="@Icons.Material.TwoTone.Create" Color="Color.Primary">Create Account</MudButton>
                </MudItem>
            </MudPaper>
        </MudGrid>
    </MudContainer>
</EditForm>

@code {
    private bool showPassword = false;

    private InputType PasswordInput => showPassword ? InputType.Text : MudBlazor.InputType.Password;
    private string PasswordInputIcon => showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    private CreateAccountForm model = new CreateAccountForm();

    private void OnShowClick()
    {
        showPassword = !showPassword;
    }
    private void CreateAccountSubmit() {

    }
    public class CreateAccountForm {
        [Required]
        [EmailAddress]
        public string email {get; set;}

        [Required]
        [StringLength(30, ErrorMessage = "Password must be at least 12 characters", MinimumLength = 12)]
        public string password {get; set;}
    }
}