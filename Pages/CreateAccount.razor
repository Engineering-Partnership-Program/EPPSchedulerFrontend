@page "/create-account"
@inherits BaseComponent
@using System.ComponentModel.DataAnnotations
@using EPPSchedulerFrontend.DataClasses

<PageTitle>EPP Scheduler | Create Account</PageTitle>

<EditForm Model="@model" OnValidSubmit="CreateAccountSubmit">
    <DataAnnotationsValidator />
    <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center mud-width-full"
                  style="height:50vh; min-height: 300px;">
        <MudGrid Spacing="2" Justify="Justify.Center" Class="align-items-center">
            <MudPaper Class="pa-4 mud-theme-primary">
                <MudItem xs="12">
                    <MudText Typo="Typo.h2" Align="Align.Center" Style="font-weight:bold">Create Account</MudText>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="model.email" For="@(() => model.email)" Label="Username"
                                  Variant="Variant.Outlined"></MudTextField>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="model.password" For="@(() => model.password)" Label="Password"
                                  Variant="Variant.Outlined" InputType="@PasswordInput" Adornment="Adornment.End"
                                  AdornmentIcon="@PasswordInputIcon" OnAdornmentClick="OnShowClick"
                                  AdornmentAriaLabel="Show Password" />
                </MudItem>
                <MudGrid>
                    <MudItem xs="6">
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" FullWidth=true
                                   StartIcon="@Icons.Material.TwoTone.Create" Color="Color.Secondary">Create Account
                        </MudButton>
                    </MudItem>
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Filled" Href="/EPPSchedulerFrontend" FullWidth=true
                                   StartIcon="@Icons.Material.TwoTone.Login" Color="Color.Secondary">Login</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudGrid>
    </MudContainer>
</EditForm>

@code {
    private bool showPassword = false;

    private InputType PasswordInput => showPassword ? InputType.Text : MudBlazor.InputType.Password;
    private string PasswordInputIcon => showPassword ? Icons.Material.Filled.Visibility :
Icons.Material.Filled.VisibilityOff;
    private CreateAccountForm model = new CreateAccountForm();

    private void OnShowClick()
    {
        showPassword = !showPassword;
    }
    private async void CreateAccountSubmit()
    {
        if (clientFactory is null || snackbar is null || navigationManager is null)
        {
            return;
        }
        HttpClient client = clientFactory.CreateClient("EPPSchedulerBackend");

        if (model.email is null || model.password is null)
        {
            snackbar.Add("THere was an errow while attempting to read your email and password, please reload the page and try again", Severity.Error);
            return;
        }
        Credentials credentials = new Credentials(model.email, model.password, Roles.User);

        HttpResponseMessage resp = await client.PostAsJsonAsync("api/Credentials/create-account", credentials);

        try
        {
            resp.EnsureSuccessStatusCode();
        }
        catch (HttpRequestException e)
        {
            if (resp.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                snackbar.Add("This email already has an account associated with it please log in", Severity.Error);
            }
            else
            {
                throw e;
            }
        }

        if (resp.StatusCode == System.Net.HttpStatusCode.OK)
        {
            Console.WriteLine("It worked navigating now");
            navigationManager.NavigateTo("dashboard", replace: true);
        }
    }
    public class CreateAccountForm
    {
        [Required]
        [EmailAddress]
        public string? email { get; set; }

        [Required]
        [StringLength(30, ErrorMessage = "Password must be at least 12 characters", MinimumLength = 12)]
        public string? password { get; set; }
    }
}