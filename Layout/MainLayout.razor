@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView Roles="Admin,Manager,User">
    <Authorized>
        <MudLayout>
            <MudAppBar>
                <MudSpacer />
                <MudMenu Dense Variant="Variant.Text" Size="Size.Medium" Color="Color.Inherit"
                         Icon="@Icons.Material.Filled.Menu">
                    <MudMenuItem Icon="@Icons.Material.TwoTone.Logout" IconColor="@Color.Primary" Label="Sign Out"
                                 Href="/" />
                </MudMenu>
            </MudAppBar>
            <MudMainContent>
                @Body
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        You are not authorized to be here
    </NotAuthorized>
</AuthorizeView>

@* Required *@
<MudThemeProvider />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />