@inherits LayoutComponentBase
<MudLayout>
    <MudAppBar>
        <MudSpacer />
        <MudMenu Dense Variant="Variant.Text" Size="Size.Medium" Color="Color.Inherit"
                 Icon="@Icons.Material.Filled.Menu">
            <MudMenuItem Icon="@Icons.Material.TwoTone.Logout" IconColor="@Color.Primary" Label="Sign Out" Href="/" />
        </MudMenu>
    </MudAppBar>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@* Required *@
<MudThemeProvider />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />